#!/usr/bin/env python3
import json
import os
import socket
import urllib.request


address = os.environ["JELLYFIN_DISCOVERY_ADDRESS"]
info_url = os.environ["JELLYFIN_INFO_URL"]
bind_address = os.environ.get("JELLYFIN_DISCOVERY_BIND", "0.0.0.0")
port = int(os.environ.get("JELLYFIN_DISCOVERY_PORT", "7359"))

sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
sock.bind((bind_address, port))

while True:
    data, peer = sock.recvfrom(4096)
    if b"Jellyfin" not in data:
        continue

    try:
        with urllib.request.urlopen(info_url, timeout=1) as response:
            info = json.load(response)
    except Exception:
        continue

    payload = {
        "Address": address,
        "Id": info.get("Id", ""),
        "Name": info.get("ServerName", "meeseeks"),
        "EndpointAddress": None,
    }
    sock.sendto(json.dumps(payload, separators=(",", ":")).encode(), peer)
