# Discord
DISCORD_TOKEN={{ vault_bitflip_patreon_bot_discord_token | default('') }}
DISCORD_CLIENT_ID={{ bitflip_patreon_bot_discord_client_id | default('') }}
DISCORD_GUILD_ID={{ bitflip_patreon_bot_discord_guild_id | default('') }}

# Patreon OAuth setup
PATREON_CLIENT_ID={{ vault_bitflip_patreon_bot_patreon_client_id | default('') }}
PATREON_CLIENT_SECRET={{ vault_bitflip_patreon_bot_patreon_client_secret | default('') }}
PATREON_SETUP_TOKEN={{ vault_bitflip_patreon_bot_setup_token | default('') }}
PATREON_OAUTH_REDIRECT_URI=https://{{ bitflip_patreon_bot_hostname }}/oauth/callback
PATREON_OAUTH_SCOPES=identity identity[email] campaigns campaigns.members

# Optional direct Patreon sync config. OAuth setup stores tokens and campaign ID in SQLite.
PATREON_ACCESS_TOKEN={{ vault_bitflip_patreon_bot_patreon_access_token | default('') }}
PATREON_REFRESH_TOKEN={{ vault_bitflip_patreon_bot_patreon_refresh_token | default('') }}
PATREON_CAMPAIGN_ID={{ bitflip_patreon_bot_patreon_campaign_id | default('') }}
PATREON_TIER_ROLE_MAP={{ bitflip_patreon_bot_tier_role_map | default('') }}
PATREON_WEBHOOK_SECRET={{ vault_bitflip_patreon_bot_webhook_secret | default('') }}

# Keep false while the official Patreon Discord bot manages Patreon roles.
MANAGE_DISCORD_ROLES={{ bitflip_patreon_bot_manage_discord_roles | default('false') }}

# Public thank-you announcements and high-tier listing.
ANNOUNCEMENTS_ENABLED={{ bitflip_patreon_bot_announcements_enabled | default('true') }}
ANNOUNCEMENT_CHANNEL_NAME={{ bitflip_patreon_bot_announcement_channel_name | default('chit-chat') }}
THANKS_TIER_NAME={{ bitflip_patreon_bot_thanks_tier_name | default('terrabyte') }}

# Runtime
DATABASE_PATH=/data/patreon-bot.sqlite
SYNC_INTERVAL_MINUTES={{ bitflip_patreon_bot_sync_interval_minutes | default(60) }}
SYNC_ON_START=true
DRY_RUN={{ bitflip_patreon_bot_dry_run | default('false') }}
LOG_LEVEL=info
WEBHOOK_PORT=3000
COMMAND_ALLOWLIST_ROLE_IDS={{ bitflip_patreon_bot_command_allowlist_role_ids | default('') }}
